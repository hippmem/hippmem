# HIPPMEM embedding configuration template
# Copy to .env and fill in real values

# Backend selection: openai-compatible | (empty = deterministic fallback)
HIPPMEM_EMBEDDING_PROVIDER=openai-compatible

# API endpoint
HIPPMEM_EMBEDDING_BASE_URL=https://api.openai.com/v1

# Model name
HIPPMEM_EMBEDDING_MODEL=text-embedding-3-small

# API key
OPENAI_API_KEY=<your-api-key-here>
